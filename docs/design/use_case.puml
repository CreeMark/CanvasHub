    usecase "Manage Projects" as UC2
    usecase "Join Project Room" as UC3
    usecase "Real-time Drawing" as UC4
    usecase "Real-time Chat" as UC5
    usecase "Save/Load Project" as UC6
    usecase "Undo/Redo" as UC7
    usecase "Clear Canvas" as UC8
}

user --> UC1
user --> UC2
user --> UC3
user --> UC4
user --> UC5
user --> UC6
user --> UC7
